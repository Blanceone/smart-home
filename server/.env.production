# 数据库配置
DATABASE_URL="postgresql://postgres:YOUR_SECURE_PASSWORD@postgres:5432/smart_home?schema=public"

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 淘宝API配置
TAOBAO_APP_KEY=your_taobao_app_key_here
TAOBAO_APP_SECRET=your_taobao_app_secret_here

# 服务配置
PORT=3000
NODE_ENV=production
APP_VERSION=1.0.0
APP_URL=https://api.smarthome.com

# JWT配置
JWT_SECRET=your_very_secure_jwt_secret_key_here_change_this
JWT_EXPIRES_IN=7d

# 文件上传配置
UPLOAD_DIR=/app/uploads

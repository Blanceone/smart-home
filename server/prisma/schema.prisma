generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(uuid())
  deviceId      String        @unique
  nickname      String
  avatar        String?
  status        Int           @default(1)
  lastLoginAt   DateTime?
  lastLoginIp   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  userInfo      UserInfo?
  houseLayout   HouseLayout?
  schemes       Scheme[]
  feedbacks     Feedback[]

  @@map("users")
}

model UserInfo {
  id                    String   @id @default(uuid())
  userId                String   @unique
  age                   String?
  occupation            String?
  familyMembers         Json?
  city                  String?
  sleepPattern          String?
  homeActivities        Json?
  entertainmentHabits   Json?
  deviceKnowledgeLevel  String?
  usedDevices           Json?
  decorStyle            String?
  colorPreferences      Json?
  preferredBrands       Json?
  isCompleted           Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_infos")
}

model HouseLayout {
  id          String    @id @default(uuid())
  userId      String    @unique
  houseType   String
  totalArea   Decimal
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rooms       Room[]

  @@map("house_layouts")
}

model Room {
  id            String    @id @default(uuid())
  layoutId      String
  name          String
  area          Decimal
  specialNeeds  String?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  houseLayout   HouseLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@index([layoutId])
  @@map("rooms")
}

model Scheme {
  id               String    @id @default(uuid())
  userId           String
  name             String
  budget           Decimal
  totalPrice       Decimal   @default(0)
  status           String    @default("draft")
  decorationGuide  Json?
  isSaved          Boolean   @default(false)
  savedAt          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  schemeDevices    SchemeDevice[]

  @@index([userId])
  @@index([status])
  @@index([isSaved])
  @@map("schemes")
}

model Device {
  id                String    @id @default(uuid())
  name              String
  brand             String
  category          String
  price             Decimal
  originalPrice     Decimal?
  description       String?
  features          Json?
  specifications    Json?
  applicableScenes  Json?
  imageUrl          String?
  images            Json?
  taobaoItemId      String?
  taobaoUrl         String?
  status            Int       @default(1)
  priceUpdatedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  schemeDevices     SchemeDevice[]

  @@index([brand])
  @@index([category])
  @@index([status])
  @@map("devices")
}

model SchemeDevice {
  id              String    @id @default(uuid())
  schemeId        String
  deviceId        String
  roomName        String?
  quantity        Int       @default(1)
  price           Decimal
  recommendReason String?
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())

  scheme          Scheme    @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  device          Device    @relation(fields: [deviceId], references: [id], onDelete: Restrict)

  @@unique([schemeId, deviceId, roomName])
  @@index([schemeId])
  @@index([deviceId])
  @@map("scheme_devices")
}

model Feedback {
  id          String    @id @default(uuid())
  userId      String
  type        String
  content     String
  relatedId   String?
  rating      Int?
  contact     String?
  status      String    @default("pending")
  reply       String?
  repliedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("feedbacks")
}
